{
  "name": "stockpilot-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:e2e && npm run test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File ./e2e/run.ps1",
    "test:e2e:install": "playwright install chromium",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc --noEmit --project tsconfig.e2e.json"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@tanstack/react-query": "5.66.0",
    "lucide-react": "0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "7.54.2",
    "react-router-dom": "6.30.4",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.10.7",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "15.14.0",
    "jsdom": "25.0.1",
    "prettier": "3.4.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.65.0",
    "vite": "^6.3.5",
    "vitest": "3.2.7"
  }
}
